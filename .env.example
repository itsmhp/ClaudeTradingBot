# ═══════════════════════════════════════════════════════════
# ClaudeTradingBot — Environment Configuration
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
#
# ═══════════════════════════════════════════════════════════


# ─── AI CONFIGURATION ─────────────────────────────────────

# Anthropic API key for Claude AI (get from: https://console.anthropic.com)
# Starts with "sk-ant-api03-"
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Claude model to use for chart analysis and signal generation
# Do not change unless you have a specific reason
CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum tokens for Claude responses (keep at 1000 for signal generation)
CLAUDE_MAX_TOKENS=1000


# ─── MT5 / EXNESS CONFIGURATION ──────────────────────────

# Your Exness MT5 account number (numeric login ID)
# Find in MT5: File → Login to Trade Account
MT5_LOGIN=12345678

# MT5 account password
# Use master password for trading, investor password for read-only
MT5_PASSWORD=your_mt5_password_here

# Exness MT5 server name
# Find in MT5: File → Login to Trade Account → Server field
# Examples: "Exness-MT5Real", "Exness-MT5Real2", "Exness-MT5Trial"
MT5_SERVER=Exness-MT5Real

# Path to MetaTrader 5 terminal executable (optional)
# Leave empty for auto-detection from default install path
# Windows default: C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PATH=


# ─── TELEGRAM NOTIFICATIONS ──────────────────────────────

# Telegram Bot token from @BotFather
# Create a bot: message @BotFather → /newbot → follow prompts
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIJKLMnopQRSTUvwxyz

# Telegram Chat ID where alerts are sent
# Find yours: message @userinfobot or @getmyid_bot
# For group chats, the ID starts with -100
TELEGRAM_CHAT_ID=-1001234567890

# Enable/disable Telegram notifications (true/false)
TELEGRAM_ENABLED=true


# ─── TRADINGVIEW / MCP CONFIGURATION ─────────────────────

# Chrome DevTools Protocol port for TradingView Desktop
# TradingView must be launched with: --remote-debugging-port=9222
TRADINGVIEW_CDP_PORT=9222

# Path to tradingview-mcp server directory
# This is where you cloned https://github.com/tradesdontlie/tradingview-mcp
MCP_SERVER_PATH=C:/Users/YOUR_USERNAME/tradingview-mcp


# ─── BOT CONFIGURATION ───────────────────────────────────

# Operating mode:
#   SIGNAL_ONLY   → Analyze charts + send Telegram alerts (no orders placed)
#   AUTO_EXECUTE  → Analyze charts + send alerts + place pending orders on MT5
BOT_MODE=SIGNAL_ONLY

# Risk percentage per trade (percentage of account equity)
# 1.0 = 1% risk per trade (recommended)
# 0.5 = 0.5% risk per trade (conservative)
# 2.0 = 2% risk per trade (aggressive)
RISK_PER_TRADE_PCT=1.0

# Minimum reward-to-risk ratio
# Signals with R:R below this value are rejected
# 2.0 means TP must be at least 2x the SL distance
DEFAULT_RR_RATIO=2.0

# Maximum number of concurrent open positions (all instruments combined)
MAX_TOTAL_POSITIONS=5

# Maximum positions per single instrument
MAX_POSITIONS_PER_PAIR=1

# Maximum daily loss percentage before bot auto-pauses
# 3.0 = bot pauses if daily loss exceeds 3% of starting equity
MAX_DAILY_LOSS_PCT=3.0

# Scan interval in seconds (how often to check for new setups)
# 300 = every 5 minutes
SCAN_INTERVAL_SECONDS=300

# Minimum confidence level to act on a signal (0-100)
# Signals below this threshold are logged but not executed
MIN_CONFIDENCE=60


# ─── DATABASE ─────────────────────────────────────────────

# SQLite database URL (relative to project root)
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost/tradingbot
DATABASE_URL=sqlite+aiosqlite:///database.db


# ─── LOGGING ──────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG during development, INFO in production
LOG_LEVEL=INFO

# Log file rotation (when a log file reaches this size, rotate)
LOG_ROTATION=10 MB

# How long to keep old log files
LOG_RETENTION=30 days

# Log format: text or json
# json is better for parsing, text is better for reading
LOG_FORMAT=text


# ─── API SERVER ───────────────────────────────────────────

# FastAPI server host (127.0.0.1 = localhost only, 0.0.0.0 = all interfaces)
API_HOST=127.0.0.1

# FastAPI server port
API_PORT=8000

# Enable auto-reload (development only)
API_RELOAD=false
